{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in the system",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The Firebase Auth UID"
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "photoURL": {
          "type": "string",
          "description": "The user's profile photo URL"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "The user's system role"
        },
        "xp": {
          "type": "number",
          "description": "Experience points earned"
        },
        "level": {
          "type": "number",
          "description": "User level"
        },
        "badges": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of earned badges"
        },
        "completedCTFs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of completed CTF scenario IDs"
        },
        "lastSeen": {
          "type": "string",
          "format": "date-time",
          "description": "The last time the user was active"
        }
      },
      "required": ["uid", "displayName", "email", "role"]
    },
    "CVE": {
      "title": "CVE",
      "description": "Cached CVE information",
      "type": "object",
      "properties": {
        "cveId": { "type": "string" },
        "description": { "type": "string" },
        "severity": { "type": "string" },
        "publishedDate": { "type": "string" },
        "lastModifiedDate": { "type": "string" }
      },
      "required": ["cveId", "description"]
    },
    "Scenario": {
      "title": "Scenario",
      "description": "A saved hacking scenario analysis",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "input": { "type": "string" },
        "analysis": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "input", "analysis", "userId", "createdAt"]
    },
    "SecurityAudit": {
      "title": "Security Audit",
      "description": "A saved SAST or DAST scan result",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mode": { "type": "string", "enum": ["SAST", "DAST"] },
        "target": { "type": "string", "description": "Code snippet or URL" },
        "findings": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "mode", "target", "findings", "createdAt"]
    },
    "RedTeamSession": {
      "title": "Red Team Session",
      "description": "A saved AI Red Teaming session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "modelName": { "type": "string" },
        "attackType": { "type": "string" },
        "input": { "type": "string" },
        "logs": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "modelName", "attackType", "input", "logs", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/cve_cache/{cveId}": {
      "schema": "CVE",
      "description": "Cache for CVE data"
    },
    "/scenarios/{scenarioId}": {
      "schema": "Scenario",
      "description": "Saved hacking scenarios"
    },
    "/security_audits/{auditId}": {
      "schema": "SecurityAudit",
      "description": "Saved security audits"
    },
    "/red_team_sessions/{sessionId}": {
      "schema": "RedTeamSession",
      "description": "Saved red team sessions"
    }
  }
}
